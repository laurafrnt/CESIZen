    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>e1b5550e-a7f9-4301-a8ea-903373380cdc</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BCrypt.Net-Next" Version="4.2.0" />
